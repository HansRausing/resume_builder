{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install && cd frontend && npm install && cd ../backend && npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
